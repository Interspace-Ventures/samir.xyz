modules = ["nodejs-20", "python-3.11", "postgresql-16"]
run = "node index.js"

[nix]
channel = "stable-25_05"
packages = ["imagemagick"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[env]
DATABASE_URL = "$DATABASE_URL"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npx prisma generate && npx next build"]
run = ["sh", "-c", "npx next start -p 3001 --hostname 0.0.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx next dev -p 5000 -H 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
